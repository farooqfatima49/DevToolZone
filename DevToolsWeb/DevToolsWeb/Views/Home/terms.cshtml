@{
    ViewData["Title"] = "Terms and Conditions - DevToolsWorld";
    Layout = "_Layout"; // your layout page
}

<section class="page-bg about-page">
    <div class="container">

        <h1>Terms and Conditions of DevToolsWorld</h1>
        <p class="subtitle">
            Please read these terms and conditions carefully before using our website and online tools.
        </p>

        <div class="about-content">

            <div class="about-card">
                <h2>1. Acceptance of Terms</h2>
                <p>
                    By accessing and using DevToolsWorld, you agree to comply with and be bound by these Terms and Conditions. If you disagree with any part, please do not use our website.
                </p>
            </div>

            <div class="about-card">
                <h2>2. Use of Tools</h2>
                <p>
                    DevToolsWorld provides free online developer tools for personal and professional use. You agree not to misuse any tool or service provided on the platform.
                </p>
            </div>

            <div class="about-card">
                <h2>3. Intellectual Property</h2>
                <p>
                    All content, design, and tools on DevToolsWorld are the intellectual property of DevToolsWorld unless stated otherwise. Unauthorized reproduction or distribution is prohibited.
                </p>
            </div>

            <div class="about-card">
                <h2>4. User Responsibility</h2>
                <p>
                    Users are responsible for any data input or output from the tools. DevToolsWorld does not guarantee the accuracy of results and is not liable for any consequences of using the tools.
                </p>
            </div>

            <div class="about-card">
                <h2>5. Privacy</h2>
                <p>
                    Please review our <a href="/privacy-policy">Privacy Policy</a> to understand how we handle your information.
                </p>
            </div>

            <div class="about-card">
                <h2>6. Limitation of Liability</h2>
                <p>
                    DevToolsWorld shall not be held liable for any damages, direct or indirect, arising from the use or inability to use the website or tools.
                </p>
            </div>

            <div class="about-card">
                <h2>7. Modifications</h2>
                <p>
                    DevToolsWorld reserves the right to update or modify these Terms and Conditions at any time. Please check this page periodically for updates.
                </p>
            </div>

            <div class="about-card">
                <h2>8. Contact Us</h2>
                <p>
                    For questions regarding these Terms and Conditions, contact us via our <a href="/contact">Contact page</a>.
                </p>
            </div>

        </div>

    </div>
</section>


<!-- SEO Meta & Open Graph -->
@section HeadContent {
    @inject Microsoft.Extensions.Configuration.IConfiguration Configuration

    @{
        var baseUrl = Configuration["AppSettings:BaseUrl"];
        var fullUrl = $"{baseUrl}{Context.Request.Path}";
    }
    <meta name="description" content="DevToolsWorld Terms and Conditions. Learn the rules and guidelines for using our free online developer tools.">
    <meta name="keywords" content="Terms and Conditions, DevToolsWorld, developer tools, JSON formatter, online utilities, free tools, web tools">
    <meta property="og:title" content="Terms and Conditions - DevToolsWorld">
    <meta property="og:description" content="DevToolsWorld Terms and Conditions. Learn the rules and guidelines for using our free online developer tools.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="@fullUrl">
    @* <meta property="og:image" content="https://yourdomain.com/images/seo-terms.jpg"> *@
}