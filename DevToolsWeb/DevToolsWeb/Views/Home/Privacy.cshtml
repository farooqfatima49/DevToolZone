@{
    ViewData["Title"] = "Privacy Policy - DevToolsZone";

    Layout = "_Layout"; // your layout page
}

<section class="page-bg about-page">
    <div class="container">

        <h1>Privacy Policy of DevToolsZone</h1>
        <p class="subtitle">
            Your privacy is important to us. This page explains how we handle your data while using DevToolsZone's free online tools.
        </p>

        <div class="about-content">

            <div class="about-card">
                <h2>1. Information We Collect</h2>
                <p>
                    DevToolsZone does not collect personally identifiable information (PII) unless voluntarily provided through contact forms or feedback submissions.
                </p>
            </div>

            <div class="about-card">
                <h2>2. Use of Information</h2>
                <p>
                    Any information provided is used only to respond to inquiries or improve our website experience. We do not sell or share your data with third parties.
                </p>
            </div>

            <div class="about-card">
                <h2>3. Cookies & Analytics</h2>
                <p>
                    We may use minimal cookies for website performance and analytics to understand usage patterns. No personal information is stored in cookies.
                </p>
            </div>

            <div class="about-card">
                <h2>4. Data Security</h2>
                <p>
                    We take reasonable measures to protect the integrity and security of data processed on our website. However, no online platform is 100% secure.
                </p>
            </div>

            <div class="about-card">
                <h2>5. Third-Party Links</h2>
                <p>
                    DevToolsZone may contain links to external websites. We are not responsible for the privacy practices of these external sites.
                </p>
            </div>

            <div class="about-card">
                <h2>6. Changes to Privacy Policy</h2>
                <p>
                    We may update our privacy policy from time to time. Please check this page periodically for updates.
                </p>
            </div>

            <div class="about-card">
                <h2>7. Contact Us</h2>
                <p>
                    If you have any questions about our privacy practices, please contact us via our <a href="/contact">Contact page</a>.
                </p>
            </div>

        </div>

    </div>
</section>
@section HeadContent {
    <meta name="description" content="DevToolsZone Privacy Policy. Learn how we handle your data while using our free online developer tools.">
    <meta name="keywords" content="Privacy Policy, DevToolsZone, developer tools, online utilities, JSON formatter, free tools">
    <meta property="og:title" content="Privacy Policy - DevToolsZone">
    <meta property="og:description" content="DevToolsZone Privacy Policy. Learn how we handle your data while using our free online developer tools.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://yourdomain.com/privacy-policy">
    <meta property="og:image" content="https://yourdomain.com/images/privacy-seo.jpg">
}