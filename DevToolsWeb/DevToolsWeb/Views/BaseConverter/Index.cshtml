@{
    ViewData["Title"] = "Free Online JSON Formatter & Validator – Format, Minify & Validate JSON";
    var faqs = new List<dynamic>
{
    new { Question = "What is Base64 encoding?", Answer = "Base64 encoding converts binary or text data into an ASCII string format using a specific character set. It is commonly used to safely transmit data through systems that only support text." },

    new { Question = "What is the difference between Base64 encoding and encryption?", Answer = "Base64 encoding is not encryption. It only changes data into a readable text format for safe transmission, while encryption protects data using a key and makes it unreadable without decryption." },

    new { Question = "Is Base64 encoding secure?", Answer = "No. Base64 encoding is not encryption. It only converts data into a different format. Anyone can decode Base64 back to its original form." },

    new { Question = "Where is Base64 used?", Answer = "Base64 is widely used in web development, APIs, email attachments, and embedding images in HTML or CSS." },

    new { Question = "How do I decode a Base64 string?", Answer = "Paste the Base64 encoded text into the input field and click the Decode button. The original text will appear in the output area." },

    new { Question = "Can I encode files using Base64?", Answer = "Yes. You can upload a file using the upload button, and the tool will convert its content into Base64 format." }
};
}
<div class="page-bg">
    <div class="glass-card">
        <h1>Base64 Encoder / Decoder</h1>
        <p class="subtitle">
            Encode plain text into Base64 or decode Base64 into readable text instantly.
        </p>
        <div class="editor-wrapper">
            <div class="editor-card">
                <div class="editor-box">
                    <textarea id="inputText" placeholder="Enter text or Base64 string here..."></textarea>
                    <div class="button-group" aria-label="Encoder tool actions">
                        <button onclick="encodeBase64()" class="btn btn-light" id="btnEncode" disabled>Encode</button>
                        <button onclick="decodeBase64()" class="btn btn-light" id="btnDecode" disabled>Decode</button>
                        <button onclick="clearFields(0)" class="btn btn-light" id="btnClear" disabled>Clear</button>

                    </div>
                    <div class="mb-3">
                        <label class="btn btn-light">
                            Upload File
                            <input type="file" id="encoderInput" hidden accept=".txt,.base64,.json">
                        </label>
                    </div>
                    
                </div>
            </div>
            <div class="editor-card">
                <div class="editor-box">
                   <textarea id="outputText" placeholder="Result will appear here..."></textarea>
                    <div class="button-group" aria-label="JSON tool actions">
                      
                        <div class="download-dropdown">
                            <button class="download-btn btn btn-light" id="btnDownload" disabled>Download ▾</button>
                            <div class="download-menu">
                                <button onclick="download('txt')">TXT</button>                                
                            </div>
                        </div><button onclick="copy()" class="btn btn-light" id="btnCopy" disabled>Copy</button>
                        <button onclick="clearFields(1)" class="btn btn-light" id="btnOutputClear" disabled>Clear</button>
                    </div>
                </div>
            </div>
        </div>
        <p id="encodermessage" class="message" role="status" aria-live="polite"></p>
        <section class="seo-content">

            <h2>What is Base64 Encoding?</h2>

            <p>
                Base64 encoding converts binary or text data into a readable ASCII string format.
                It is widely used in web development for encoding data in URLs, APIs, and email attachments.
            </p>

            <h2>How to Use the Base64 Encoder Decoder</h2>

            <ol>
                <li>Paste your text or Base64 string in the input box.</li>
                <li>Click <strong>Encode</strong> to convert text into Base64.</li>
                <li>Click <strong>Decode</strong> to convert Base64 back to readable text.</li>
                <li>Copy the result using the copy button.</li>
            </ol>

            <h2>Common Uses of Base64</h2>
            <ul>
                <li>Encoding API credentials</li>
                <li>Email attachments</li>
                <li>Embedding images in HTML or CSS</li>
                <li>Secure data transfer</li>
            </ul>
            <partial name="~/Views/Shared/PartialViews/_FAQ.cshtml" model="faqs" />
            <p>Check out our <a href="/json-formatter">JSON Formatter</a> or <a href="/json-to-csharp">JSON to C# Converter</a> for easy formatting.</p>

        </section>
    </div>
</div>
<script src="~/js/base64encoder.js"></script>
@section HeadContent {
    <partial name="~/Views/Shared/PartialViews/_SeoMetaTags.cshtml" model="faqs" ,
             view-data='new ViewDataDictionary(ViewData)
         {
             ["Title"] = "Base64 Encode Decode Online | Free Base64 Encoder Decoder Tool",
             ["Description"] = "Free online Base64 encoder and decoder tool. Encode text to Base64 or decode Base64 strings instantly. Fast, secure and easy to use developer utility.",
             ["keywords"] = "base64 encode, base64 decode, base64 encoder online, base64 decoder online, encode base64, decode base64, developer tools",
             ["image"]="json-formatter-preview.png"
     }' />
}
   
