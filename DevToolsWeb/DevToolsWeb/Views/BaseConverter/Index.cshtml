    <title>Base64 Encode Decode Online | Free Base64 Encoder Decoder Tool</title>

    <meta name="description" content="Free online Base64 encoder and decoder tool. Encode text to Base64 or decode Base64 strings instantly. Fast, secure and easy to use developer utility.">

    <meta name="keywords" content="base64 encode, base64 decode, base64 encoder online, base64 decoder online, encode base64, decode base64, developer tools">

    <meta name="robots" content="index, follow">

    <link rel="canonical" href="https://yourdomain.com/base64-encode-decode" />

    <meta property="og:title" content="Base64 Encode Decode Online Tool">
    <meta property="og:description" content="Encode text to Base64 or decode Base64 strings instantly using this free developer tool.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://yourdomain.com/base64-encode-decode">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Base64 Encode Decode Online Tool">
    <meta name="twitter:description" content="Convert text to Base64 or decode Base64 instantly with this free online tool.">

    <script type="application/ld+json">
        {
         "@@context": "https://schema.org",
         "@@type": "WebApplication",
         "name": "Base64 Encoder Decoder",
         "url": "https://yourdomain.com/base64-encode-decode",
