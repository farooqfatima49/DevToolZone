@{
    ViewData["Title"] = "Free Online JSON Formatter & Validator – Format, Minify & Validate JSON";
    var faqs = new List<dynamic>
    {
        new { Question = "What is a JSON Formatter and Validator?", Answer = "A JSON Formatter and Validator is a tool that formats raw JSON into a readable structure and checks for syntax errors. It helps developers debug and clean API responses quickly." },
        new { Question = "Is this JSON formatter free to use?", Answer = "Yes, our JSON Formatter & Validator is completely free to use with no limitations, sign-ups, or hidden charges." },
        new { Question = "Does this tool store my JSON data?", Answer = "No, your data is never stored or sent to any server. All processing happens directly in your browser for complete privacy." },
        new { Question = "Can I format large JSON files?", Answer = " Yes, the tool is optimized to handle large JSON files efficiently with smooth formatting and expandable structure view." },
        new { Question = "What is the difference between format and minify in JSON?", Answer = " Formatting makes JSON readable with proper indentation, while minifying removes spaces and reduces file size for production use." },
        new { Question = "How do I fix invalid JSON using this tool?", Answer = "You can use the \"Fix JSON\" feature to automatically correct common syntax issues like missing commas, quotes, or brackets." },
        new { Question = "Can I upload a JSON file instead of pasting it?", Answer = "Yes, you can upload a JSON file directly using the upload option and then format or validate it instantly." },
        new { Question = "What features does this JSON tool provide?", Answer = " This tool provides formatting, validation, minification, fixing JSON errors, file upload support, copy, and download options." }
    };
}

<div class="page-bg">
    <div class="glass-card">
        <h1>Free Online JSON Formatter & Validator</h1>
        <p class="subtitle">
            Format, validate, and minify JSON online. Free & secure JSON formatting tool.
        </p>

        <div class="editor-wrapper">
            <div class="editor-card">
                <div class="">
                    <div class="editor-box">
                        <label>Input JSON</label>
                        <div id="jsonInput" class="editor"></div>
                        <div class="button-group" aria-label="JSON tool actions">
                            <button id="btnFormat" class="btn btn-light" onclick="formatJson()" disabled>Format</button>
                            <button id="btnMinify" class="btn btn-light" onclick="minifyJson()" disabled>Minify</button>
                            <button id="btnValidate" class="btn btn-light" onclick="validateJson()" disabled>Validate</button>
                            <button id="btnFix" class="btn btn-light" onclick="fixJson()" disabled>Fix Json</button>

                        </div>
                        <div class="mb-3">
                            <label class="btn btn-light">
                                Upload JSON File
                                <input type="file" id="jsonFileInput" hidden accept=".json">
                            </label>
                        </div>
                    </div>
                </div>
            </div><div class="editor-card">
                <div class="">

                    <div class="editor-box">
                        <label>Formatted Output</label>
                        <div id="jsonOutput" class="editor"></div>
                        <div id="editorFindBar" class="editor-find-bar hidden">

                            <!-- Find Section -->
                            <button onclick="closeFindBar()" class="icon-btn close-btn" title="Close">
                                <i class="fa fa-times"></i>
                            </button>
                            <div class="editor-card">
                                <div class="find-group">
                                    <div class="input-wrapper">
                                        <input type="text" id="editorFind" placeholder="Find..." autocomplete="off" />
                                        <button id="searchBtn" class="icon-btn search-btn" title="Search">
                                            <i class="fa fa-search"></i>
                                        </button>
                                    </div>

                                    <button onclick="findPrev()" class="icon-btn nav-btn" title="Previous">
                                        <i class="fa fa-chevron-up"></i>
                                    </button>
                                    <button onclick="findNext()" class="icon-btn nav-btn" title="Next">
                                        <i class="fa fa-chevron-down"></i>
                                    </button>

                                    <span id="matchCount" class="match-counter">0 / 0</span>


                                </div>

                                <!-- Replace Section -->
                                <div class="replace-group" id="replaceGroup">
                                    <div class="input-wrapper">
                                        <input type="text" id="editorReplace" placeholder="Replace..." />
                                        <div class="dropdown">
                                            <button class="btn-light btn-dropdown">Actions <i class="fa fa-caret-down"></i></button>
                                            <div class="dropdown-content">
                                                <a href="#" onclick="replaceCurrent()">Replace</a>
                                                <a href="#" onclick="replaceAll()">Replace All</a>
                                                <a href="#" onclick="replaceKeyValue()">Replace Key-Value</a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                        <div class="button-group" aria-label="JSON tool actions">
                            <div class="download-dropdown">
                                <button class="download-btn btn btn-light" id="btnDownload" disabled>Download ▾</button>

                                <div class="download-menu" disabled>
                                    <button onclick="download('txt')">TXT</button>
                                    <button onclick="download('json')">JSON</button>

                                </div>
                            </div>
                            <button id="btnClear" class="btn btn-light" onclick="clearFields()" disabled>Clear</button>
                            <button id="btnCopy" class="btn btn-light" onclick="copyOutput()" disabled>Copy</button>
                            <button id="btnExpand" class="btn btn-light" disabled>Expand</button>
                        </div>
                    </div>
                </div>
            </div>

        </div>
        <p id="formattermessage" class="message" role="status" aria-live="polite"></p>
        <section class="seo-content">
            <h2>About JSON Formatter & Validator</h2>
            <p>
                Our online JSON Formatter helps developers and non-developers quickly format, minify, and validate JSON data.
                The formatted JSON is easy to read, editable, and can be copied or downloaded instantly.
            </p>

            <h2>How to Use the JSON Formatter</h2>
            <ol>
                <li>Paste your JSON into the Input JSON box.</li>
                <li>Click "Format" to beautify the JSON.</li>
                <li>Use "Minify" to compress JSON for production.</li>
                <li>"Validate" will check if your JSON is correct.</li>
                <li>Copy or expand/collapse JSON for better readability.</li>
            </ol>

            <h2>Benefits of Using Our Tool</h2>
            <ul>
                <li>Instant formatting and validation</li>
                <li>Clean and readable output</li>
                <li>No data is stored on the server</li>
                <li>Works on all modern browsers and devices</li>
            </ul>
            <partial name="~/Views/Shared/PartialViews/_FAQ.cshtml" model="faqs" />            
            <p>Check out our <a href="/json-comparer">JSON Comparer</a> or <a href="/json-converter">JSON Converter</a> for easy formatting.</p>

        </section>
    </div>
</div>

<script src="~/js/json-formatter.js"></script>
@section HeadContent {
    <partial name="~/Views/Shared/PartialViews/_SeoMetaTags.cshtml" model="faqs" ,
         view-data='new ViewDataDictionary(ViewData)
         {
             ["Title"] = "Free JSON Formatter & Validator Online",
             ["Description"] = "Format, validate, beautify and minify JSON instantly with our free online JSON Formatter tool. Fast, secure, and easy-to-use JSON validator with error detection.",
             ["keywords"] = "JSON Formatter, JSON Validator, JSON Beautifier, JSON Minify, JSON Viewer, Online JSON Tool, Free JSON Formatter",
             ["image"]="json-formatter-preview.png"
     }' />
}

