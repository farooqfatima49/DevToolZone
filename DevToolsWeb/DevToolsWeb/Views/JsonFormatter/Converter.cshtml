@{
    var type = (ViewBag.Type ?? "csharp").ToString().ToLower();
    string pageTitle = type switch
    {
        "csharp" => "JSON to C# Model Converter Online",
        "typescript" => "JSON to TypeScript Interface Generator",
        "sql" => "JSON to SQL Table Converter",
        "xml" => "JSON to XML Converter",
        _ => "Free Online JSON Converter – Convert JSON to C# / SQL /typescript /XML"
    };
    ViewData["Title"] = pageTitle;
    var faqs = new List<dynamic>
    {
        new { Question = "Which conversions does this tool support?", Answer = "This tool supports JSON to C#, JSON to SQL, JSON to TypeScript, JSON to XML, and JSON formatting & validation." },

        new { Question = "Is my data safe while converting JSON?", Answer = "Yes, your data is completely safe because all conversions happen in your browser and nothing is stored on our servers." },

        new { Question = "Can I convert large JSON files?", Answer = "Yes, you can convert large JSON files depending on your browser performance since all processing is done client-side." },

        new { Question = "Does JSON to C# conversion generate classes?", Answer = "Yes, the tool automatically generates C# model classes based on your JSON structure." },

        new { Question = "Can I convert nested JSON structures?", Answer = "Yes, nested JSON objects and arrays are fully supported for all conversion types including C#, SQL, and TypeScript." },

        new { Question = "Do I need to install any software?", Answer = "No installation is required. This tool runs directly in your browser." },

        new { Question = "Is this tool free?", Answer = "Yes, it is completely free." },

        new { Question = "Is my JSON stored?", Answer = "No, all processing is done client-side." }
    };
}

<div class="page-bg">
  <div class="glass-card">

        <!-- Header -->
        <h1>@pageTitle</h1>
        <p class="subtitle">Convert JSON to C# classes, typescript or SQL scripts online instantly. Free, fast, and easy JSON to C# / typescript / SQL converter.</p>
       
        <!-- Toolbar -->
        <div class="converter-toolbar">
            <select id="converterType">
                <option value="csharp">C# Model</option>
                <option value="typescript">TypeScript Interface</option>
                <option value="sql">SQL Table</option>
                <option value="xml">XML</option>
            </select>

            <button id="convertBtn" class="btn btn-light" disabled>Convert</button>
            <button id="clearBtn" class="btn btn-light" disabled>Clear</button>
            <button id="copyBtn" class="btn btn-light" disabled>Copy Output</button>
        </div>

        <!-- Editors Section -->
        <div class="editor-wrapper">

            <!-- Input JSON -->
            <div class="editor-card">
            <div class="editor-box">
                <label>Input JSON</label>
                <div id="jsonInput" class="editor"></div>
                    <div class="mb-3">
                        <label class="btn btn-light">
                            Upload JSON File
                            <input type="file" id="jFConverterInput" hidden accept=".json">
                        </label>
                    </div>
                </div>
            </div>
            <!-- Output -->
            <div class="editor-card">
            <div class="editor-box">
                <label>Generated Model</label>
                <pre id="outputEditor" class="output-editor"></pre>
                    <div class="download-dropdown">
                        <button class="download-btn btn btn-light" id="btnDownload" disabled>Download ▾</button>

                        <div class="download-menu">
                            <button onclick="download('txt')">TXT</button>
                            <button onclick="download('json')">JSON</button>
                            <button onclick="download('xml')">XML</button>
                        </div>
                    </div>
            </div>
        </div>
        </div>
        <p id="converterMessage" class="message" role="status" aria-live="polite"></p>
        <section class="seo-content">
            <h2>About JSON Converter</h2>
            <p>
                Our JSON converter allows developers to generate classes instantly from JSON data.
                This tool is useful for creating strongly typed models .
            </p>

            <h2>How to Convert JSON</h2>
            <ol>
                <li>Paste your JSON in the editor.</li>
                <li>Select type in which you want to convert json.</li>
                <li>Click Convert.</li>
                <li>Copy the generated Model.</li>
            </ol>

            <h2>Example</h2>
                <pre>
                {
                    "name": "John",
                    "age": 25
                }
                </pre>
            <partial name="~/Views/Shared/PartialViews/_FAQ.cshtml" model="faqs" />

           
            <p>Check out our <a href="/json-formatter">JSON Formatter</a> or <a href="/json-comparer">JSON Comparer</a> for easy formatting.</p>

        </section>
           </div>
</div>

    <script>
        const selectedType = "@type";
        document.getElementById("converterType").value = selectedType;
    </script>

<script src="~/js/json-converter.js"></script>
@section HeadContent {

    <partial name="~/Views/Shared/PartialViews/_SeoMetaTags.cshtml" model="faqs" ,
             view-data='new ViewDataDictionary(ViewData)
         {
             ["Title"] = "JSON to C#, SQL & TypeScript Converter Online",
             ["Description"] = "Convert JSON to C#, SQL table schema, and TypeScript interfaces instantly. Free online JSON code converter tool for developers. Fast, accurate, and secure.",
             ["keywords"] = "JSON to C#, JSON to SQL, JSON to TypeScript, JSON to TS Interface, JSON to C# Class, JSON Code Converter, JSON to Model Generator",
             ["image"]="json-formatter-preview.png"
     }' />
}
